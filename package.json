{
  "name": "shiftly",
  "version": "0.1.0",
  "private": true,
  "description": "SHIFTLY — Enterprise Workforce Marketplace",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:dev": "turbo run build:dev",
    "build:test": "turbo run build:test",
    "build:performance": "turbo run build:performance",
    "build:modeloffice": "turbo run build:modeloffice",
    "build:production": "turbo run build:production",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\" --ignore-path .prettierignore",
    "clean": "turbo run clean && rimraf node_modules",
    "postinstall": "pnpm run db:generate",
    "db:generate": "pnpm --filter @shiftly/api run db:generate",
    "db:migrate": "pnpm --filter @shiftly/api prisma migrate dev",
    "db:migrate:deploy": "pnpm --filter @shiftly/api prisma migrate deploy",
    "db:seed": "pnpm --filter @shiftly/api run db:seed",
    "db:studio": "pnpm --filter @shiftly/api prisma studio"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.9.6",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.11",
    "turbo": "^2.10.5",
    "typescript-eslint": "^8.65.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "pnpm": {
    "overrides": {
      "tar": ">=6.2.2",
      "vitest": ">=2.0.0",
      "js-yaml": ">=4.3.0",
      "@opentelemetry/propagator-jaeger": ">=1.30.1",
      "webpack": ">=5.104.0",
      "body-parser": ">=1.20.6",
      "esbuild@<=0.24.2": ">=0.25.0",
      "tmp@<=0.2.3": ">=0.2.4",
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "multer@<2.1.0": ">=2.1.0",
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0",
      "multer@<2.1.1": ">=2.1.1",
      "file-type@>=13.0.0 <21.3.1": ">=21.3.1",
      "file-type@>=20.0.0 <=21.3.1": ">=21.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "lodash@>=4.0.0 <=4.17.23": ">=4.18.0",
      "lodash@<=4.17.23": ">=4.18.0",
      "vite@<=6.4.1": ">=6.4.2",
      "@nestjs/core@<=11.1.17": ">=11.1.18",
      "@nestjs/microservices@<=11.1.18": ">=11.1.19",
      "uuid@<11.1.1": ">=11.1.1",
      "qs@>=6.11.1 <=6.15.1": ">=6.15.2",
      "vitest@<3.2.6": ">=3.2.6",
      "@opentelemetry/auto-instrumentations-node@<0.75.0": ">=0.75.0",
      "@opentelemetry/sdk-node@<0.217.0": ">=0.217.0",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "tmp@<0.2.6": ">=0.2.6",
      "vite@<=6.4.2": ">=6.4.3",
      "@opentelemetry/core@<2.8.0": ">=2.8.0",
      "multer@>=1.0.0 <2.2.0": ">=2.2.0",
      "multer@>=2.0.0-alpha.1 <2.2.0": ">=2.2.0",
      "@opentelemetry/propagator-jaeger@<2.9.0": ">=2.9.0"
    }
  }
}
