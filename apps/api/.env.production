# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_VERSION=v1
CORS_ORIGINS=http://localhost:5173

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL="postgresql://shiftly:shiftly_dev_password@localhost:5432/shiftly?schema=public"
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=shiftly_redis_password
REDIS_TLS=false

# ─── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=shiftly-api
KAFKA_GROUP_ID=shiftly-consumer-group
KAFKA_SSL=false

# ─── JWT (MUST be >= 32 chars — use `openssl rand -hex 32` to generate) ───────
JWT_ACCESS_SECRET=CHANGE_ME_USE_OPENSSL_RAND_HEX_32_FOR_PRODUCTION_MINIMUM_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_USE_DIFFERENT_OPENSSL_RAND_HEX_32_FOR_REFRESH_TOKEN
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── AWS (use LocalStack values for local dev) ────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_S3_BUCKET=shiftly-uploads
AWS_S3_PRESIGNED_EXPIRE=3600
AWS_SES_FROM_EMAIL=noreply@shiftly.com
AWS_SES_FROM_NAME=SHIFTLY
AWS_SNS_SMS_TOPIC_ARN=arn:aws:sns:ap-south-1:000000000000:shiftly-sms

# Override endpoint to use LocalStack
AWS_ENDPOINT_URL=http://localhost:4566

# ─── OpenSearch ───────────────────────────────────────────────────────────────
OPENSEARCH_ENDPOINT=http://localhost:9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=

# ─── AI / OpenAI ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_OPENAI_API_KEY

# ─── Platform ─────────────────────────────────────────────────────────────────
PLATFORM_FEE_PERCENT=10
OTP_EXPIRE_SECONDS=300
OTP_MAX_ATTEMPTS=5
